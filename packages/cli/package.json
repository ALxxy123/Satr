{
  "name": "@satr/cli",
  "version": "0.1.0",
  "description": "CLI for Satr.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "ai",
    "cli",
    "dlp",
    "privacy",
    "security"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahmadmubaraki/satr.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/ahmadmubaraki/satr#readme",
  "bugs": {
    "url": "https://github.com/ahmadmubaraki/satr/issues"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "satr": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@satr/core": "workspace:*",
    "@satr/node": "workspace:*",
    "@satr/rules": "workspace:*",
    "commander": "^12.0.0"
  },
  "devDependencies": {}
}
